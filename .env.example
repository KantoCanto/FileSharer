APP_URL=http://localhost:3000

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
ADMIN_EMAIL=owner@example.com
ALLOWED_EMAILS=

# Database
DATABASE_URL=mysql://USER:PASSWORD@HOST:PORT/DATABASE

# Oracle Cloud Object Storage S3-compatible API
OCI_REGION=eu-frankfurt-1
OCI_NAMESPACE=
OCI_BUCKET=file-transfer
OCI_S3_ENDPOINT=https://<namespace>.compat.objectstorage.<region>.oraclecloud.com
OCI_ACCESS_KEY=
OCI_SECRET_KEY=

# Limits
MAX_TOTAL_ACTIVE_STORAGE_BYTES=10737418240
SOFT_STORAGE_LIMIT_BYTES=9663676416
MAX_FILE_SIZE_BYTES=2147483648
RETENTION_DAYS=7
SIGNED_URL_TTL_SECONDS=900
ADMIN_PURGE_CONFIRMATION_TEXT=PURGE ALL FILES
